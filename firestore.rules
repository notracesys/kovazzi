
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- VISITS RULES ---
    // Permite que qualquer pessoa crie um registro de visita, mas ninguém possa deletar ou listar (exceto no dashboard)
    match /visits/{visitId} {
      allow create: if true; 
      allow read, list: if true; // Em um app real, aqui restringiríamos apenas para admins
    }

    // --- COLLECTION RULES ---
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);

      match /sessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId);

        match /quizResponses/{quizResponseId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update, delete: if isOwner(userId);
        }

        match /freeFireAccounts/{freeFireAccountId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update, delete: if isOwner(userId);
        }

        match /analysisResults/{analysisResultId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update, delete: if isOwner(userId);
        }

        match /servicePurchases/{servicePurchaseId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update, delete: if isOwner(userId);
        }
      }
    }
  }
}

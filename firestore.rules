
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- VISITS RULES ---
    match /visits/{visitId} {
      allow create: if true; 
      // Apenas usuários autenticados podem ver os dados de tráfego
      allow read, list: if isSignedIn(); 
    }

    // --- CHECKOUT CLICKS RULES ---
    match /checkoutClicks/{clickId} {
      allow create: if true;
      // Apenas usuários autenticados podem ver os dados de conversão
      allow read, list: if isSignedIn();
    }

    // --- COLLECTION RULES (USUÁRIOS) ---
    match /users/{userId} {
      allow get, list, create, update, delete: if isSignedIn() && request.auth.uid == userId;

      match /sessions/{sessionId} {
        allow get, list, create, update, delete: if isSignedIn() && request.auth.uid == userId;

        match /quizResponses/{quizResponseId} {
          allow get, list, create, update, delete: if isSignedIn() && request.auth.uid == userId;
        }

        match /freeFireAccounts/{freeFireAccountId} {
          allow get, list, create, update, delete: if isSignedIn() && request.auth.uid == userId;
        }

        match /analysisResults/{analysisResultId} {
          allow get, list, create, update, delete: if isSignedIn() && request.auth.uid == userId;
        }

        match /servicePurchases/{servicePurchaseId} {
          allow get, list, create, update, delete: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }
  }
}
